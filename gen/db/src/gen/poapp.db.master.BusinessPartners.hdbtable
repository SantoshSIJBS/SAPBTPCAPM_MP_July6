COLUMN TABLE poapp_db_master_BusinessPartners (
  NODE_KEY NVARCHAR(36) NOT NULL,
  BP_ROLE NVARCHAR(2),
  EMAIL NVARCHAR(255),
  MOBILE NVARCHAR(32),
  FAX NVARCHAR(32),
  WEB NVARCHAR(255),
  BP_ID NVARCHAR(36),
  COMPANY_NAME NVARCHAR(255),
  ADDRESS_GUID_NODE_KEY NVARCHAR(36),
  PRIMARY KEY(NODE_KEY)
)