COLUMN TABLE poapp_db_master_Addresses (
  STREET NVARCHAR(255),
  POSTAL NVARCHAR(12),
  CITY NVARCHAR(255),
  COUNTRY NVARCHAR(255),
  BUILDING NVARCHAR(255),
  NODE_KEY NVARCHAR(36) NOT NULL,
  ADDRESS_TYPE NVARCHAR(32),
  VAL_START DATE,
  VAL_END DATE,
  LATITUDE DECIMAL,
  LONGITUDE DECIMAL,
  PRIMARY KEY(NODE_KEY)
)